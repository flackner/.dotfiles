[alias]
    # The Essentials
    st = status
    co = checkout
    ci = commit
    br = branch
    df = diff

    # Utilities
    unstage = reset HEAD --
    last = log -1 HEAD
    
    # Pretty Log (A graph view of your history)
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[user]
	name = fablackner
	email = 35771682+fablackner@users.noreply.github.com

[init]
    defaultBranch = main